<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <title>Scatter Mahjong - Ultimate Neon</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: radial-gradient(circle at center, #0a0a12, #020204 90%);
      --cyber-yellow: #fcee0a;
      --tosca-neon: #00f5ff;
      --ferrari-red: #ff2800;
      --success-green: #39ff14;
      --panel-bg: rgba(10, 10, 20, 0.85);
      --glass-border: rgba(255,255,255,0.1);
      --shadow-glow: rgba(0,245,255,0.25);
    }

    * { box-sizing: border-box; font-family: 'Orbitron', monospace; font-weight: 600; }
    body, html {
      margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden;
      background: var(--bg);
      display: flex; align-items: center; justify-content: center;
    }

    #vortexCanvas { position: fixed; inset: 0; z-index: 0; pointer-events: none; }

    .main-wrapper {
      position: relative;
      z-index: 10;
      width: 95%;
      max-width: 1200px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .moving-h1 {
      color: var(--cyber-yellow);
      letter-spacing: 12px;
      margin-bottom: 25px;
      font-size: 3rem;
      text-align: center;
      animation: floatMove 3s ease-in-out infinite;
      text-transform: uppercase;
      text-shadow:
        0 0 10px var(--cyber-yellow),
        0 0 25px var(--tosca-neon),
        0 0 50px var(--ferrari-red),
        0 0 80px var(--cyber-yellow);
    }

    .container-outer {
      position: relative;
      padding: 5px;
      border-radius: 25px;
      overflow: hidden;
      width: 100%;
      background: linear-gradient(120deg, var(--tosca-neon), var(--ferrari-red), var(--cyber-yellow));
      background-size: 400% 400%;
      animation: borderFlow 8s ease infinite;
      box-shadow: 0 0 30px var(--tosca-neon), 0 0 60px var(--ferrari-red);
    }

    @keyframes borderFlow {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    .container {
      width: 100%;
      padding: 35px;
      background: var(--panel-bg);
      backdrop-filter: blur(25px);
      border-radius: 20px;
      border-left: 5px solid var(--ferrari-red);
      border-bottom: 15px solid var(--tosca-neon);
      position: relative;
      z-index: 1;
      box-shadow:
        inset 0 0 40px rgba(255,255,255,0.05),
        0 0 50px var(--shadow-glow);
      transition: 0.3s;
    }

    textarea {
      width: 100%;
      height: 180px;
      background: rgba(0,0,0,0.75);
      border: 2px solid var(--ferrari-red);
      color: #fff;
      padding: 18px;
      font-family: 'Consolas', monospace;
      font-size: 15px;
      border-radius: 15px;
      resize: none;
      outline: none;
      transition: 0.3s;
      box-shadow: inset 0 0 15px rgba(0,245,255,0.1);
    }
    textarea:focus {
      border: 2px solid var(--tosca-neon);
      box-shadow: 0 0 30px var(--tosca-neon), 0 0 50px var(--ferrari-red);
    }

    #upInfo { width: 100%; margin: 25px 0; display: flex; justify-content: center; }
    #upSpan {
      display: flex; align-items: center; justify-content: center;
      width: 100%; height: 70px;
      background: rgba(0,0,0,0.8);
      border: 2px solid var(--tosca-neon);
      font-size: 30px;
      color: var(--tosca-neon);
      letter-spacing: 6px;
      border-radius: 15px;
      text-shadow: 0 0 15px var(--tosca-neon), 0 0 25px var(--cyber-yellow);
      box-shadow: inset 0 0 20px var(--shadow-glow), 0 0 30px var(--shadow-glow);
      user-select: none;
      transition: 0.2s;
    }

    .konslet-text {
      color: var(--success-green) !important;
      text-shadow: 0 0 15px var(--success-green), 0 0 35px var(--success-green);
      animation: blink-konslet 0.15s infinite alternate !important;
    }
    .up-flash-konslet {
      border-color: var(--success-green) !important;
      animation: blink-konslet 0.12s infinite alternate !important;
    }
    @keyframes blink-konslet {
      0%, 100% { opacity: 1; filter: contrast(1.4); }
      50% { opacity: 0.2; filter: contrast(0.7); }
    }

    .btn-copy {
      margin-top: 25px;
      padding: 18px 70px;
      background: linear-gradient(135deg, var(--ferrari-red), var(--tosca-neon));
      color: #fff;
      border: none;
      font-size: 17px;
      border-radius: 50px;
      cursor: pointer;
      outline: none;
      transition: 0.3s ease;
      box-shadow: 0 0 15px var(--ferrari-red), 0 0 25px var(--tosca-neon);
    }
    .btn-copy:hover {
      transform: scale(1.1);
      box-shadow: 0 0 25px var(--ferrari-red), 0 0 50px var(--tosca-neon);
    }
    .btn-copy:active { transform: scale(0.95); }

    .table-responsive {
      width: 100%;
      margin-top: 25px;
      max-height: 280px;
      overflow-y: auto;
      border-radius: 15px;
      background: rgba(0,0,0,0.6);
      box-shadow: inset 0 0 15px var(--shadow-glow);
    }
    table {
      width: 100%;
      border-collapse: collapse;
    }
    thead th {
      background: rgba(0,0,0,0.9);
      color: var(--cyber-yellow);
      padding: 12px;
      font-size: 12px;
      border-bottom: 2px solid var(--tosca-neon);
      position: sticky; top: 0;
      text-shadow: 0 0 10px var(--cyber-yellow);
    }
    tbody td {
      padding: 12px;
      text-align: center;
      color: var(--tosca-neon);
      font-size: 14px;
      border-bottom: 1px solid rgba(0,245,255,0.1);
      transition: transform 0.2s, background 0.2s;
    }
    tbody tr:hover { background: rgba(0,245,255,0.15); transform: scale(1.02); }

    @keyframes floatMove {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }
  </style>
</head>
<body>
<canvas id="vortexCanvas"></canvas>
<div class="main-wrapper">
  <h1 class="moving-h1">SCATTER MAHJONG</h1>
  <div class="container-outer">
    <div class="container">
      <textarea id="inputData" tabindex="1" placeholder="Tempel data di sini..."></textarea>
      <div id="upInfo"><span id="upSpan">UP KEMENANGAN : -</span></div>
      <div class="table-responsive" tabindex="0">
        <table>
          <thead>
            <tr>
              <th>USER ID</th><th>NAMA</th><th>REKENING</th><th>GAME</th><th>TICKET</th><th>MENANG</th><th>BET</th>
            </tr>
          </thead>
          <tbody id="tbodyBonus">
            <tr><td colspan="7" style="color:#666; padding: 40px;">[ AWAITING_INPUT ]</td></tr>
          </tbody>
        </table>
      </div>
      <div style="text-align:center;">
        <button class="btn-copy" id="btnCopy" tabindex="2" onclick="copyTableData()">SALIN DATA</button>
      </div>
    </div>
  </div>
</div>

<script>
  // === Canvas Vortex ===
  const vCanvas = document.getElementById('vortexCanvas');
  const vCtx = vCanvas.getContext('2d');
  let vParticles = [];
  const colors = ['#ff2800','#00f5ff','#fcee0a'];
  function resize(){ vCanvas.width=innerWidth; vCanvas.height=innerHeight; }
  window.addEventListener('resize', resize); resize();
  class Part{constructor(){this.reset()} reset(){this.x=vCanvas.width/2;this.y=vCanvas.height/2;this.oldX=this.x;this.oldY=this.y;this.size=Math.random()*2+1;this.angle=Math.random()*Math.PI*2;this.speed=Math.random()*0.3+0.1;this.color=colors[Math.floor(Math.random()*colors.length)];} update(){this.oldX=this.x;this.oldY=this.y;this.x+=Math.cos(this.angle)*this.speed;this.y+=Math.sin(this.angle)*this.speed;this.speed*=1.035;if(this.x<0||this.x>vCanvas.width||this.y<0||this.y>vCanvas.height)this.reset();} draw(){vCtx.strokeStyle=this.color;vCtx.lineWidth=this.size;vCtx.beginPath();vCtx.moveTo(this.oldX,this.oldY);vCtx.lineTo(this.x,this.y);vCtx.stroke();}}
  for(let i=0;i<120;i++) vParticles.push(new Part());
  function animate(){vCtx.fillStyle='rgba(5,5,5,0.3)';vCtx.fillRect(0,0,vCanvas.width,vCanvas.height);vParticles.forEach(p=>{p.update();p.draw();});requestAnimationFrame(animate);}
  animate();

  // === JS Parsing dan Render Table ===
  const ta = document.getElementById("inputData");
  const upBox = document.getElementById("upSpan");

  ta.addEventListener("input",function(){
    const text=(this.value||"").trim();
    if(!text){upBox.textContent="UP KEMENANGAN : -";upBox.classList.remove("up-flash-konslet");document.getElementById("tbodyBonus").innerHTML='<tr><td colspan="7" style="color:#666; padding: 40px;">[ AWAITING_INPUT ]</td></tr>';return;}
    const blocks=text.split(/\n\s*\n/);
    const rows=blocks.map(parseBlock).filter(Boolean);
    renderTable(rows);
  });

  function parseBlock(block){
    let lines=block.split('\n');
    let data={userId:"-",permainan:"-",ticket:"-",menang:0,taruhan:0};
    let ticketMatches=block.match(/\d{18,20}/g);
    if(ticketMatches){let freq={};ticketMatches.forEach(t=>freq[t]=(freq[t]||0)+1);data.ticket=Object.keys(freq).reduce((a,b)=>freq[a]>freq[b]?a:b);}
    lines.forEach((line,i)=>{
      let clean=line.trim(); let l=clean.toLowerCase();
      if(l.includes("mahjong")||l.includes("ways")||l.includes("wild bandito")||l.includes("lucky neko")||l.includes("pg soft")||l.includes("pragmatic")) data.permainan=clean;
      if(l.includes("credit")){let val=extractMoney(clean);if(val===0&&lines[i+1]) val=extractMoney(lines[i+1]);data.menang+=val;}
      if(l.includes("debit")){let val=extractMoney(clean);if(val===0&&lines[i+1]) val=extractMoney(lines[i+1]);data.taruhan=val;}
      if(clean.length>=3&&clean.length<=15&&/^[a-zA-Z0-9_]+$/.test(clean)&&!/(idr|credit|debit|ext|pg|balance|mahjong|ways|wild|neko)/i.test(l)) data.userId=clean;
    });
    if(data.permainan==="-"&&lines[0]) data.permainan=lines[0].trim();
    return (data.menang>0||data.userId!="-")?data:null;
  }

  function extractMoney(str){return parseInt(str.replace(/[.,]/g,"").replace(/[^\d]/g,""))||0;}
  function renderTable(rows){
    const tbody=document.getElementById("tbodyBonus");
    tbody.innerHTML="";
    upBox.classList.remove("up-flash-konslet");
    rows.forEach(r=>{
      let up=r.taruhan>0?(r.menang/r.taruhan):0;
      upBox.textContent=`UP KEMENANGAN : ${Math.round(up)} x`;
      let tr=document.createElement("tr");
      let isBigWin=up>=300;if(isBigWin) upBox.classList.add("up-flash-konslet");
      const flashClass=isBigWin?'class="konslet-text"':'';
      tr.innerHTML=`
        <td ${flashClass}>${r.userId}</td>
        <td ${flashClass}>-</td>
        <td ${flashClass}>-</td>
        <td ${flashClass}>${r.permainan}</td>
        <td style="font-size:11px;">${r.ticket}</td>
        <td ${flashClass} style="color:#fff;">${r.menang.toLocaleString()}</td>
        <td ${flashClass} style="color:var(--cyber-yellow);">${r.taruhan.toLocaleString()}</td>
      `;
      tbody.appendChild(tr);
    });
  }

  function copyTableData(){
    const btn=document.getElementById("btnCopy");
    let out="";
    document.querySelectorAll("#tbodyBonus tr").forEach(tr=>{
      let tds=tr.querySelectorAll("td");
      if(tds.length===7&&tds[0].innerText!=="[ AWAITING_INPUT ]") out+=Array.from(tds).map(td=>td.innerText).join("\t")+"\n";
    });
    if(out){navigator.clipboard.writeText(out).then(()=>{btn.innerText="BERHASIL DISALIN!";setTimeout(()=>{btn.innerText="SALIN DATA";},1200);});}
  }
</script>
</body>
</html>
